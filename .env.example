# Copy to .env (gitignored) and fill in the values you need.
# scripts/daily.py and scripts/ingest_url.py auto-load this file at startup.

# Required: Anthropic API key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: switch the scoring model. Defaults to claude-opus-4-7.
# Use claude-haiku-4-5 for ~5× cheaper scoring at slight quality cost.
# CAUSAL_KB_MODEL=claude-haiku-4-5
